# Zen Platform Environment Variables
# Copy this file to .env and fill in the values

# === CORS ===
# Comma-separated list of allowed origins for API requests
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# === Production Host Authorization ===
# Comma-separated list of allowed hosts (production only)
ALLOWED_HOSTS=your-domain.com

# === Rails ===
RAILS_LOG_LEVEL=info
RAILS_ENV=development

# === JWT Secret (production: configure via credentials) ===
# JWT_SECRET=<hex string generated by: ruby -rsecurerandom -e 'puts SecureRandom.hex(32)'>

# === API Secrets (for HMAC signature auth) ===
# Add via: bin/rails credentials:edit
# api_secrets:
#   your_app_id: your_secret_key

# === SMTP (optional) ===
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=your_username
# SMTP_PASSWORD=your_password
