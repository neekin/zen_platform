<div class="landing">
  <!-- Animated Background -->
  <div class="animated-bg">
    <div class="gradient-orb orb-1"></div>
    <div class="gradient-orb orb-2"></div>
    <div class="gradient-orb orb-3"></div>
  </div>

  <!-- Navigation -->
  <nav class="nav-glass">
    <div class="nav-content">
      <div class="nav-logo">
        <img src="/logo-mark.svg" alt="Zen" class="logo-icon-svg" />
        <span class="logo-text">Zen Platform</span>
      </div>
      <div class="nav-links">
        <a href="#features">特性</a>
        <a href="#dsl">DSL</a>
        <a href="#stack">技术栈</a>
        <a href="https://zen.justfunit.net" class="nav-link-external">使用文档</a>
      </div>
      <div class="nav-actions">
        <a href="/admin" class="btn-nav">进入后台</a>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        v<%= File.read(Rails.root.join("VERSION")).strip rescue "0.0.0" %> — 开源免费
      </div>
      <h1 class="hero-title">
        <span class="gradient-text">声明式</span>全栈应用<br>生成平台
      </h1>
      <p class="hero-desc">
        在 Model 中用 DSL 声明字段、关联、展示方式<br>
        <span class="highlight">自动生成完整的管理后台 + API</span>
      </p>
      <div class="hero-actions">
        <a href="/admin" class="btn btn-primary magnetic">
          <span>🚀</span> 立即开始
        </a>
        <a href="#dsl" class="btn btn-glass magnetic">
          <span>▶️</span> 观看演示
        </a>
      </div>
      <div class="hero-stats">
        <div class="stat-item" data-target="20">
          <span class="stat-number">20+</span>
          <span class="stat-label">富文本插件</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item" data-target="5">
          <span class="stat-number">5</span>
          <span class="stat-label">产品形态</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item" data-target="4">
          <span class="stat-number">4</span>
          <span class="stat-label">认证方式</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item" data-target="98">
          <span class="stat-number">98%</span>
          <span class="stat-label">代码自动生成</span>
        </div>
      </div>
    </div>
    <div class="hero-scroll-indicator">
      <div class="scroll-mouse">
        <div class="scroll-wheel"></div>
      </div>
      <span>向下滚动</span>
    </div>
  </section>

  <!-- DSL Demo Section -->
  <section class="section" id="dsl">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">声明即所得</span>
        <h2 class="section-title">一行 DSL，生成整个后台</h2>
        <p class="section-desc">在 Model 中声明一次，前端自动渲染。无需手写 CRUD。</p>
      </div>
      <div class="code-showcase">
        <div class="code-tabs">
          <button class="code-tab active" data-tab="model">Model DSL</button>
          <button class="code-tab" data-tab="controller">Controller</button>
          <button class="code-tab" data-tab="result">生成结果</button>
        </div>
        <div class="code-panel" id="panel-model">
          <div class="code-header">
            <div class="code-dots">
              <span></span><span></span><span></span>
            </div>
            <span class="code-filename">app/models/article.rb</span>
            <span class="code-language">Ruby</span>
          </div>
          <pre><code><span class="kw">class</span> <span class="cls">Article</span> &lt; <span class="cls">ApplicationRecord</span>
  <span class="kw">include</span> <span class="mod">Zen::ModelDsl</span>

  <span class="fn">field</span> <span class="sym">:title</span>, <span class="sym">:string</span>, <span class="key">required:</span> <span class="bool">true</span>
  <span class="fn">field</span> <span class="sym">:body</span>, <span class="sym">:rich_text</span>
  <span class="fn">field</span> <span class="sym">:status</span>, <span class="sym">:enum</span>, <span class="key">values:</span> <span class="val">%w[draft published]</span>

  <span class="fn">belongs_to</span> <span class="sym">:category</span>

  <span class="fn">display</span> <span class="kw">do</span>
    <span class="fn">list</span> <span class="kw">do</span>
      <span class="fn">column</span> <span class="sym">:title</span>, <span class="key">link:</span> <span class="bool">true</span>
      <span class="fn">column</span> <span class="sym">:status</span>, <span class="key">badge:</span> <span class="bool">true</span>
    <span class="kw">end</span>
    <span class="fn">form</span> <span class="kw">do</span>
      <span class="fn">field</span> <span class="sym">:title</span>
      <span class="fn">field</span> <span class="sym">:body</span>, <span class="key">as:</span> <span class="sym">:rich_text</span>
    <span class="kw">end</span>
  <span class="kw">end</span>
<span class="kw">end</span></code></pre>
        </div>
        <div class="code-panel hidden" id="panel-controller">
          <div class="code-header">
            <div class="code-dots">
              <span></span><span></span><span></span>
            </div>
            <span class="code-filename">app/controllers/admin/articles_controller.rb</span>
            <span class="code-language">Ruby</span>
          </div>
          <pre><code><span class="cmt"># 自动生成，无需手写</span>
<span class="kw">class</span> <span class="cls">Admin::ArticlesController</span> &lt; <span class="cls">AdminController</span>
  <span class="kw">include</span> <span class="mod">Pagy::Method</span>

  <span class="fn">def</span> <span class="fn">index</span>
    q = <span class="cls">Article</span>.<span class="fn">ransack</span>(search_params)
    <span class="var">@pagy</span>, articles = <span class="fn">pagy</span>(<span class="sym">:offset</span>, q.<span class="fn">result</span>, <span class="var">**</span><span class="fn">pagy_params</span>)
    <span class="fn">render</span> <span class="key">inertia:</span> <span class="str">"admin/articles/Index"</span>,
      <span class="key">props:</span> <span class="fn">zen_props</span>(<span class="cls">Article</span>, articles: articles)
  <span class="kw">end</span>
<span class="kw">end</span></code></pre>
        </div>
        <div class="code-panel hidden" id="panel-result">
          <div class="code-header">
            <div class="code-dots">
              <span></span><span></span><span></span>
            </div>
            <span class="code-filename">生成的内容</span>
            <span class="code-language">✨</span>
          </div>
          <div class="result-grid">
            <div class="result-card glass-card">
              <div class="result-icon">📋</div>
              <div class="result-title">CRUD 表格</div>
              <div class="result-desc">自动生成列表、搜索、分页、过滤</div>
            </div>
            <div class="result-card glass-card">
              <div class="result-icon">📝</div>
              <div class="result-title">表单页面</div>
              <div class="result-desc">Modal 或独立页面，支持富文本</div>
            </div>
            <div class="result-card glass-card">
              <div class="result-icon">🔐</div>
              <div class="result-title">权限控制</div>
              <div class="result-desc">Pundit Policy + Rolify 角色</div>
            </div>
            <div class="result-card glass-card">
              <div class="result-icon">📊</div>
              <div class="result-title">API 端点</div>
              <div class="result-desc">RESTful API + Swagger 文档</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="section section-dark" id="features">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">核心特性</span>
        <h2 class="section-title">为什么选择 Zen Platform？</h2>
        <p class="section-desc">我们重新定义了管理后台的开发方式</p>
      </div>
      <div class="features-grid">
        <div class="feature-card glass-card" data-aos="fade-up">
          <div class="feature-icon-wrap">
            <span class="feature-icon">📝</span>
          </div>
          <h3>Model DSL</h3>
          <p>声明字段、关联、展示配置，自动生成 JSON Schema 驱动前端渲染。一次声明，多处使用。</p>
          <div class="feature-tag">声明式</div>
        </div>
        <div class="feature-card glass-card" data-aos="fade-up" data-aos-delay="100">
          <div class="feature-icon-wrap">
            <span class="feature-icon">✏️</span>
          </div>
          <h3>富文本引擎</h3>
          <p>Lexical 驱动，20 个插件：Mermaid 图表、KaTeX 公式、代码高亮、视频嵌入、@提及。</p>
          <div class="feature-tag">20+ 插件</div>
        </div>
        <div class="feature-card glass-card" data-aos="fade-up" data-aos-delay="200">
          <div class="feature-icon-wrap">
            <span class="feature-icon">🎨</span>
          </div>
          <h3>多产品形态</h3>
          <p>CRUD 表格、看板拖拽、日历视图、画廊网格 — 一行 DSL 切换产品形态。</p>
          <div class="feature-tag">5 种形态</div>
        </div>
        <div class="feature-card glass-card" data-aos="fade-up" data-aos-delay="300">
          <div class="feature-icon-wrap">
            <span class="feature-icon">🔐</span>
          </div>
          <h3>企业级权限</h3>
          <p>Pundit + Rolify RBAC，动态权限矩阵，资源级授权控制，支持多角色。</p>
          <div class="feature-tag">RBAC</div>
        </div>
        <div class="feature-card glass-card" data-aos="fade-up" data-aos-delay="400">
          <div class="feature-icon-wrap">
            <span class="feature-icon">📊</span>
          </div>
          <h3>审计日志</h3>
          <p>PaperTrail 全量追踪，支持一键还原，操作历史可追溯，包含 request context。</p>
          <div class="feature-tag">全量追踪</div>
        </div>
        <div class="feature-card glass-card" data-aos="fade-up" data-aos-delay="500">
          <div class="feature-icon-wrap">
            <span class="feature-icon">🚀</span>
          </div>
          <h3>一键生成</h3>
          <p>rails generate zen:admin 自动生成 Controller + 页面 + 路由 + Policy + Spec。3 分钟上线。</p>
          <div class="feature-tag">脚手架</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tech Stack Section -->
  <section class="section" id="stack">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">技术栈</span>
        <h2 class="section-title">现代化技术栈</h2>
        <p class="section-desc">选择成熟、稳定、高性能的技术</p>
      </div>
      <div class="stack-grid">
        <div class="stack-card glass-card">
          <div class="stack-icon">🔧</div>
          <div class="stack-label">Backend</div>
          <div class="stack-items">
            <span class="stack-item-tag">Rails 8.1</span>
            <span class="stack-item-tag">Ruby 4.0</span>
            <span class="stack-item-tag">SQLite3</span>
            <span class="stack-item-tag">Solid Queue</span>
          </div>
        </div>
        <div class="stack-card glass-card">
          <div class="stack-icon">🎨</div>
          <div class="stack-label">Frontend</div>
          <div class="stack-items">
            <span class="stack-item-tag">React 19</span>
            <span class="stack-item-tag">TypeScript</span>
            <span class="stack-item-tag">Ant Design 6</span>
            <span class="stack-item-tag">Vite 8</span>
          </div>
        </div>
        <div class="stack-card glass-card">
          <div class="stack-icon">📝</div>
          <div class="stack-label">Rich Text</div>
          <div class="stack-items">
            <span class="stack-item-tag">Lexical 0.46</span>
            <span class="stack-item-tag">20 Plugins</span>
            <span class="stack-item-tag">Mermaid</span>
            <span class="stack-item-tag">KaTeX</span>
          </div>
        </div>
        <div class="stack-card glass-card">
          <div class="stack-icon">🔑</div>
          <div class="stack-label">Auth</div>
          <div class="stack-items">
            <span class="stack-item-tag">Session</span>
            <span class="stack-item-tag">JWT</span>
            <span class="stack-item-tag">API Key</span>
            <span class="stack-item-tag">HMAC</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section section-cta">
    <div class="container">
      <div class="cta-glass">
        <div class="cta-content">
          <h2>准备好开始了吗？</h2>
          <p>3 条命令，30 秒上手。开源、免费、可商用。</p>
          <div class="cta-terminal">
            <div class="terminal-header">
              <div class="terminal-dots">
                <span></span><span></span><span></span>
              </div>
              <span class="terminal-title">Terminal — Zen Platform</span>
            </div>
            <div class="terminal-body">
              <div class="terminal-line">
                <span class="terminal-prompt">$</span>
                <span class="terminal-cmd">git clone https://github.com/neekin/zen_platform.git</span>
              </div>
              <div class="terminal-line">
                <span class="terminal-prompt">$</span>
                <span class="terminal-cmd">cd zen_platform && bin/setup</span>
              </div>
              <div class="terminal-line">
                <span class="terminal-prompt">$</span>
                <span class="terminal-cmd">bin/dev</span>
              </div>
              <div class="terminal-line terminal-success">
                <span class="terminal-check">✓</span>
                <span>服务器启动成功 → </span><span class="terminal-link">http://localhost:3000</span>
              </div>
            </div>
          </div>
          <div class="cta-actions">
            <a href="https://github.com/neekin/zen_platform" class="btn btn-primary magnetic">
              <span>⭐</span> GitHub
            </a>
            <a href="/admin" class="btn btn-glass magnetic">
              <span>🚀</span> 在线演示
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container footer-content">
      <div class="footer-left">
        <span class="footer-logo"><img src="/logo-mark.svg" alt="Zen" class="footer-logo-svg" /> Zen Platform</span>
        <span class="footer-copy">&copy; 2026</span>
      </div>
      <div class="footer-links">
        <a href="https://github.com/neekin/zen_platform">GitHub</a>
        <a href="https://zen.justfunit.net">使用文档</a>
        <a href="https://github.com/neekin/zen_platform/issues">问题反馈</a>
      </div>
      <div class="footer-right">
        <span>Built with</span>
        <span class="footer-heart">❤️</span>
        <span>Rails + React + Inertia.js</span>
      </div>
    </div>
  </footer>
</div>

<style>
:root {
  --bg: #0a0f1e;
  --bg-card: rgba(20, 27, 45, 0.7);
  --bg-glass: rgba(255, 255, 255, 0.05);
  --border: rgba(100, 140, 200, 0.15);
  --text: rgba(255, 255, 255, 0.85);
  --text-secondary: rgba(255, 255, 255, 0.55);
  --primary: #1677FF;
  --primary-glow: rgba(22, 119, 255, 0.3);
  --success: #52c41a;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

.landing {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.6;
  min-height: 100vh;
  overflow-x: hidden;
}

.container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

/* ===== Animated Background ===== */
.animated-bg {
  position: fixed;
  inset: 0;
  z-index: 0;
  overflow: hidden;
  pointer-events: none;
}

.gradient-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(100px);
  opacity: 0.4;
  animation: float 20s infinite ease-in-out;
}

.orb-1 {
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(22, 119, 255, 0.3), transparent);
  top: -200px;
  left: -200px;
  animation-delay: 0s;
}

.orb-2 {
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, rgba(100, 60, 255, 0.2), transparent);
  top: 50%;
  right: -200px;
  animation-delay: -7s;
}

.orb-3 {
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, rgba(0, 200, 150, 0.15), transparent);
  bottom: -100px;
  left: 30%;
  animation-delay: -14s;
}

@keyframes float {
  0%, 100% { transform: translate(0, 0) scale(1); }
  25% { transform: translate(50px, -50px) scale(1.1); }
  50% { transform: translate(-30px, 30px) scale(0.9); }
  75% { transform: translate(40px, 50px) scale(1.05); }
}

/* ===== Navigation ===== */
.nav-glass {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background: rgba(10, 15, 30, 0.8);
  backdrop-filter: blur(20px) saturate(180%);
  border-bottom: 1px solid var(--border);
  padding: 0 24px;
}

.nav-content {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 64px;
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 18px;
  font-weight: 600;
}

.logo-icon { font-size: 24px; }
.logo-icon-svg {
  width: 28px;
  height: 28px;
  display: block;
  filter: drop-shadow(0 2px 8px rgba(212, 165, 55, 0.3));
}
.footer-logo-svg {
  width: 22px;
  height: 22px;
  display: inline-block;
  vertical-align: middle;
  margin-right: 6px;
  margin-top: -2px;
}

.nav-links {
  display: flex;
  gap: 32px;
}

.nav-links a {
  color: var(--text-secondary);
  text-decoration: none;
  font-size: 14px;
  transition: color 0.2s;
}

.nav-links a:hover { color: var(--primary); }

.btn-nav {
  padding: 8px 20px;
  background: var(--primary);
  color: #fff;
  border-radius: 8px;
  text-decoration: none;
  font-size: 14px;
  font-weight: 500;
  transition: all 0.2s;
}

.btn-nav:hover {
  opacity: 0.9;
  transform: translateY(-1px);
}

/* ===== Hero Section ===== */
.hero {
  position: relative;
  z-index: 1;
  padding: 180px 0 100px;
  text-align: center;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.hero-content {
  position: relative;
  z-index: 1;
  max-width: 800px;
  margin: 0 auto;
  padding: 0 24px;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 20px;
  background: rgba(22, 119, 255, 0.1);
  border: 1px solid rgba(22, 119, 255, 0.3);
  border-radius: 20px;
  font-size: 13px;
  color: var(--primary);
  margin-bottom: 32px;
  animation: fadeInUp 0.6s ease-out;
}

.badge-dot {
  width: 8px;
  height: 8px;
  background: var(--success);
  border-radius: 50%;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.hero-title {
  font-size: 64px;
  font-weight: 800;
  letter-spacing: -2px;
  line-height: 1.1;
  margin-bottom: 24px;
  animation: fadeInUp 0.6s ease-out 0.1s both;
}

.gradient-text {
  background: linear-gradient(135deg, #1677FF 0%, #00D4AA 50%, #1677FF 100%);
  background-size: 200% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  animation: gradientMove 3s linear infinite;
}

@keyframes gradientMove {
  0% { background-position: 0% center; }
  100% { background-position: 200% center; }
}

.hero-desc {
  font-size: 18px;
  color: var(--text-secondary);
  margin-bottom: 40px;
  line-height: 1.8;
  animation: fadeInUp 0.6s ease-out 0.2s both;
}

.highlight {
  color: var(--primary);
  font-weight: 500;
}

.hero-actions {
  display: flex;
  gap: 16px;
  justify-content: center;
  margin-bottom: 64px;
  animation: fadeInUp 0.6s ease-out 0.3s both;
}

.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 32px;
  border-radius: 10px;
  font-size: 16px;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  border: none;
  cursor: pointer;
}

.btn-primary {
  background: linear-gradient(135deg, #1677FF, #0095FF);
  color: #fff;
  box-shadow: 0 4px 20px rgba(22, 119, 255, 0.4);
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 30px rgba(22, 119, 255, 0.6);
}

.btn-glass {
  background: var(--bg-glass);
  color: var(--text);
  border: 1px solid var(--border);
  backdrop-filter: blur(10px);
}

.btn-glass:hover {
  border-color: var(--primary);
  color: var(--primary);
  transform: translateY(-2px);
}

.hero-stats {
  display: flex;
  gap: 48px;
  justify-content: center;
  align-items: center;
  animation: fadeInUp 0.6s ease-out 0.4s both;
}

.stat-item { text-align: center; }

.stat-number {
  display: block;
  font-size: 36px;
  font-weight: 800;
  background: linear-gradient(135deg, #1677FF, #00D4AA);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 4px;
}

.stat-label {
