#!/usr/bin/env bash

# 一键清理脚手架生成的测试文件
# 使用: bin/cleanup_scaffold

set -e

echo "🧹 开始清理脚手架生成的文件..."

# 1. 清理 spec 目录中的测试文件（保留核心测试）
echo "📂 清理 spec 目录..."
rm -f spec/models/article_spec.rb
rm -f spec/models/product_spec.rb
rm -f spec/models/category_spec.rb
rm -rf spec/features/*

# 2. 清理临时文件
echo "🗑️  清理临时文件..."
rm -rf tmp/cache/*
rm -rf tmp/pids/*
rm -rf tmp/sockets/*

# 3. 清理日志（保留最近的）
echo "📝 清理日志文件..."
find log -name "*.log" -mtime +7 -delete 2>/dev/null || true

# 4. 重新创建必要的空目录
echo "📁 重新创建目录..."
mkdir -p spec/models spec/controllers spec/policies spec/factories

echo "✅ 清理完成！"
echo ""
echo "📊 当前测试文件清单："
find spec -name "*_spec.rb" | sort
